# Viajjei — variáveis de ambiente
# Copie pra .env.local e preencha. Não commitar .env.local.

# ─── Supabase (obrigatório pra rodar dev e prod) ──────────────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxx...
# Server-only (Netlify Functions). Bypass de RLS — só use no backend.
SUPABASE_SERVICE_KEY=eyJxxx...

# ─── Mercado Pago (obrigatório pra cobrar) ────────────────────────────
# APP_USR-* = produção, TEST-* = sandbox
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxx
# Secret gerado no painel MP → Webhooks → Configurar → "Sua chave secreta"
# Sem isso, webhook-mp loga warning mas aceita sem validar HMAC (permissivo)
MP_WEBHOOK_SECRET=

# ─── IA / Jei (pelo menos UM dos três) ────────────────────────────────
# Primário: Claude Haiku 4.5 ($1/M in, $5/M out, $10/1k web_search)
ANTHROPIC_API_KEY=sk-ant-xxx
# Fallback 1: OpenAI GPT-4o-mini
OPENAI_API_KEY=sk-xxx
# Fallback 2: Google Gemini 2.5 Flash
GEMINI_API_KEY=xxx

# ─── Rate limit (opcional — stub mode se ausente) ─────────────────────
# Free tier Upstash: 10k req/dia
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ─── Observabilidade (opcional — stub mode se ausente) ────────────────
# Frontend
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
# Backend
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
