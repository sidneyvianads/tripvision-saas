# Viajjei — variáveis de ambiente
# Copie pra .env.local e preencha. Não commitar .env.local.
#
# Referência completa em README.md (tabela "Variáveis de ambiente") com
# link de onde pegar cada uma + comportamento quando ausente.

# ─── Supabase (obrigatório) ──────────────────────────────────────────
# Onde: app.supabase.com → projeto → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxx...
# Server-only (Netlify Functions). BYPASS DE RLS — só use no backend.
# Trate como senha root. NUNCA commitar, NUNCA logar, NUNCA expor no frontend.
SUPABASE_SERVICE_KEY=eyJxxx...

# ─── Mercado Pago (obrigatório pra cobrar) ────────────────────────────
# APP_USR-* = produção, TEST-* = sandbox
# Onde: mercadopago.com.br → Suas integrações → app → Credenciais
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxx
# Onde: MP → Webhooks → Configurar → "Sua chave secreta"
# Sem isso, webhook-mp loga warning mas aceita sem validar HMAC (modo
# permissivo — OK em dev, NUNCA em prod).
MP_WEBHOOK_SECRET=

# ─── IA / Jei (pelo menos UM dos três; ANTHROPIC recomendado) ─────────
# Primário: Claude Haiku 4.5 ($1/M in, $5/M out, $10/1k web_search)
# Onde: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxx
# Fallback 1: OpenAI GPT-4o-mini ($0.15/M in, $0.60/M out)
# Onde: platform.openai.com → API keys
OPENAI_API_KEY=sk-xxx
# Fallback 2: Google Gemini 2.5 Flash ($0.075/M in, $0.30/M out)
# Onde: aistudio.google.com → API key
GEMINI_API_KEY=xxx

# ─── Rate limit (opcional — stub mode se ausente) ─────────────────────
# Free tier Upstash: 10k commands/dia
# Onde: upstash.com → Redis → Details → REST URL + REST Token
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ─── Resend (opcional — stub mode se ausente) ─────────────────────────
# Free tier: 100 emails/dia, 3k/mês.
# Setup:
#   1. Sign up em https://resend.com
#   2. Verificar viajjei.com.br (SPF + DKIM no DNS via painel Resend)
#   3. Setar a API key abaixo
# Sem isso, convite ainda é criado e o link é copiável na UI — só não
# manda email automático.
RESEND_API_KEY=re_xxx
# Sender: domínio precisa estar verificado no Resend.
INVITE_SENDER_EMAIL=Viajjei <convites@viajjei.com.br>

# ─── Observabilidade (opcional — stub mode se ausente) ────────────────
# Sentry — error tracking. Onde: sentry.io → Project → Settings → Client Keys (DSN)
# Frontend
VITE_SENTRY_DSN=
# Backend (Netlify Functions)
SENTRY_DSN=

# PostHog — product analytics. Onde: posthog.com → Project Settings → Project API Key
# Frontend
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
# Backend
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ─── Auto-injetadas pelo Netlify (NÃO setar manualmente em prod) ──────
# URL: domínio canônico do deploy atual (preview ou prod). Usado em
# back_url do MP, notification_url do webhook, etc.
# DEPLOY_PRIME_URL: similar, com fallback pra URL.
# Em dev local sem essas vars, o código cai em fallback "https://viajjei.com.br".
# URL=
# DEPLOY_PRIME_URL=
